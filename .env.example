# App
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080

# Database driver: mysql | postgres | sqlserver | sqlite
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=secret
DB_NAME=starter_db
DB_SSLMODE=disable

# JWT
JWT_SECRET=your-super-secret-key-change-this
JWT_ACCESS_EXPIRE=15
JWT_REFRESH_EXPIRE=10080

# Email
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_pass
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Starter API

# Email Verification (true/false)
EMAIL_VERIFICATION_REQUIRED=true

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Facebook OAuth2
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URL=http://localhost:8080/api/v1/auth/facebook/callback

# Storage
STORAGE_PATH=./storage/photos
STORAGE_URL=http://localhost:8080/storage/photos

# Password Reset Token Expire (minutes)
RESET_TOKEN_EXPIRE=60
